{
  "name": "EPL Engagement Platform (Debian operator console)",
  "build": {
    "dockerfile": "Dockerfile",
    "context": "."
  },
  "features": {
    "ghcr.io/devcontainers/features/docker-in-docker:2": {
      "version": "latest",
      "moby": true,
      "dockerDashComposeVersion": "v2"
    }
  },
  "mounts": [
    "source=epl-tailscale,target=/var/lib/tailscale,type=volume",
    "source=epl-cloudflared,target=/etc/cloudflared,type=volume"
  ],
  "remoteUser": "root",
  "postCreateCommand": "${containerWorkspaceFolder}/.devcontainer/post-create.sh ${containerWorkspaceFolder}",
  "customizations": {
    "vscode": {
      "extensions": [
        "ms-azuretools.vscode-docker",
        "ms-vscode.makefile-tools",
        "redhat.vscode-yaml",
        "cloudflare.cloudflare-workers-bindings"
      ],
      "settings": {
        "terminal.integrated.defaultProfile.linux": "bash"
      }
    }
  },
  "containerEnv": {
    "EPL_ROLE": "engagement-platform-operator",
    "EPL_OPENWRT_VERSION": "23.05.3",
    "EPL_TARGET": "ramips/mt76x8",
    "EPL_OPENWRT_SIBLING_IMAGE": "openwrt/rootfs:x86-64-23.05.3",
    "EPL_OPENWRT_SIBLING_NAME": "ep-devcontainer"
  }
}
